# sourced from ~/.bashrc — add: [ -f ~/.bashrc_extra ] && source ~/.bashrc_extra

[ -f ~/.aliases ] && source ~/.aliases

export EDITOR=nvim
export VISUAL=nvim

export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.cargo/bin:$PATH"       # Rust (rustup)
export PATH="$HOME/.local/go/bin:$PATH"    # Go toolchain
export GOPATH="$HOME/go"
export PATH="$GOPATH/bin:$PATH"            # go install binaries
